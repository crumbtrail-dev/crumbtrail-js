{
  "name": "crumbtrail-node",
  "version": "0.9.0",
  "description": "Self-hosted Crumbtrail server, MCP evidence tools and Express middleware for capturing and diagnosing bugs. See https://crumbtrail.ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CrumbtrailDev/crumbtrail-cli.git",
    "directory": "packages/node"
  },
  "keywords": [
    "crumbtrail",
    "debugging",
    "bug-reporting",
    "ai-agents",
    "coding-agent",
    "session-replay",
    "observability",
    "developer-tools",
    "mcp",
    "model-context-protocol",
    "express",
    "middleware",
    "server",
    "self-hosted",
    "opentelemetry"
  ],
  "mcpName": "io.github.CrumbtrailDev/crumbtrail",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "crumbtrail-server": "./dist/cli.cjs"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify:package-runtime": "pnpm build && node scripts/verify-package-runtime.mjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "crumbtrail-core": "workspace:^",
    "node-sql-parser": "^5.4.0",
    "protobufjs": "^8.6.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "express": "^5.2.1",
    "typescript": "^5.7.0"
  },
  "homepage": "https://crumbtrail.ai",
  "bugs": {
    "url": "https://github.com/CrumbtrailDev/crumbtrail-cli/issues"
  }
}
