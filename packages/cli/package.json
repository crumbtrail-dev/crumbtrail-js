{
  "name": "crumbtrail",
  "version": "0.6.0",
  "description": "Set up Crumbtrail in one command: npx crumbtrail detects your framework, wires in the SDK, and verifies the first event. See https://crumbtrail.ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CrumbtrailDev/crumbtrail-cli.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "crumbtrail",
    "debugging",
    "bug-reporting",
    "ai-agents",
    "coding-agent",
    "session-replay",
    "observability",
    "developer-tools",
    "cli",
    "setup",
    "wizard",
    "install",
    "codegen"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "crumbtrail": "./dist/cli.cjs"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "pretest": "pnpm --filter crumbtrail-detect-core build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "crumbtrail-core": "workspace:^",
    "crumbtrail-install-shared": "workspace:^",
    "crumbtrail-detect-core": "workspace:^"
  },
  "homepage": "https://crumbtrail.ai",
  "bugs": {
    "url": "https://github.com/CrumbtrailDev/crumbtrail-cli/issues"
  }
}
