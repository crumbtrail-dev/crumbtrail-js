{
  "name": "crumbtrail-react",
  "version": "0.2.3",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^17.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  },
  "license": "MIT",
  "homepage": "https://crumbtrail.ai",
  "bugs": {
    "url": "https://github.com/CrumbtrailDev/crumbtrail-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CrumbtrailDev/crumbtrail-cli.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  },
  "description": "React bindings for Crumbtrail: an error boundary that captures the session, and a hook that records component state with a bug report. See https://crumbtrail.ai",
  "keywords": [
    "crumbtrail",
    "debugging",
    "bug-reporting",
    "ai-agents",
    "coding-agent",
    "session-replay",
    "observability",
    "developer-tools",
    "react",
    "error-boundary",
    "hooks",
    "react-error-handling",
    "state"
  ]
}
