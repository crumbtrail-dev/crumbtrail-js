{
  "name": "crumbtrail-react",
  "version": "0.2.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^17.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "license": "MIT",
  "homepage": "https://github.com/crumbtrail-dev/crumbtrail-js/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/crumbtrail-dev/crumbtrail-js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crumbtrail-dev/crumbtrail-js.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  }
}
