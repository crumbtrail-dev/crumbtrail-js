{
  "name": "crumbtrail-tauri",
  "version": "0.2.3",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0"
  },
  "peerDependencies": {
    "crumbtrail-core": "workspace:^"
  },
  "devDependencies": {
    "crumbtrail-core": "workspace:^",
    "typescript": "^5.8.3",
    "tsup": "^8.5.0",
    "vitest": "^4.1.10"
  },
  "license": "MIT",
  "homepage": "https://crumbtrail.ai",
  "bugs": {
    "url": "https://github.com/CrumbtrailDev/crumbtrail-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CrumbtrailDev/crumbtrail-cli.git",
    "directory": "packages/tauri"
  },
  "publishConfig": {
    "access": "public"
  },
  "description": "Tauri v2 plugin for Crumbtrail: capture desktop app sessions over native IPC, no server process required. See https://crumbtrail.ai",
  "keywords": [
    "crumbtrail",
    "debugging",
    "bug-reporting",
    "ai-agents",
    "coding-agent",
    "session-replay",
    "observability",
    "developer-tools",
    "tauri",
    "tauri-plugin",
    "desktop",
    "rust",
    "ipc"
  ]
}
